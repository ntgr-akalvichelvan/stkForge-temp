enable
configure
router ospf
router-id {{ ospf.router_id }}

! Make all interfaces passive by default
passive-interface default

! Enable OSPF adjacency only on router-facing uplinks
{% if ospf.non_passive_interfaces is defined %}
{% for intf in ospf.non_passive_interfaces %}
no passive-interface {{ intf }}
{% endfor %}
{% endif %}

! Advertise networks into OSPF
{% for net in ospf.networks %}
network {{ net.network }} {{ net.wildcard }} area {{ net.area }}
{% endfor %}

! Route summarization at the ABR (Core → Corporate)
{% if ospf.area_ranges is defined %}
{% for range in ospf.area_ranges %}
area {{ range.area }} range {{ range.prefix }} {{ range.mask }}
{% endfor %}
{% endif %}

exit
write memory
y
logout

